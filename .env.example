# =============================================================================
# WhatsApp Server Environment Variables
# =============================================================================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whatsapp

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Session Management
AUTO_CONNECT_SESSIONS=false

# Rate Limiting (optional, has defaults)
# REST_RATE_LIMIT=100
# MCP_RATE_LIMIT=30

# ── MCP Proxy Configuration ──────────────────────────────────────────────────
# URL of the REST API server that MCP will proxy requests to.
MCP_API_BASE_URL=http://localhost:3000
# API Key for MCP to authenticate with the REST API.
# Create with role "operator" via: POST /v1/admin/api-keys
MCP_API_KEY=

# Logging
# LOG_LEVEL=info
